<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

        <!--
            ParKing - Custom Checkstyle Configuration

            Rules enforced:
            - PascalCase for class names
            - camelCase for methods and variables
            - UPPER_SNAKE_CASE for constants
            - Opening and closing brace (same as google)
            - Braces required for if/for/while/do
            - Max line length: 150 characters
            - No empty blocks
            - No duplicate or unused imports
            - No magic numbers (except common ones and HTTP codes)
            - No empty statements
            - equals() must override hashCode()

            Rules intentionally NOT enforced:
            - Star imports allowed
            - Javadoc not required
            - Import order not enforced
            - Indentation not enforced by checkstyle (use IntelliJ formatter)
        -->

<module name="Checker">

    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

<!-- ================================================================ -->
<!-- FILE-LEVEL CHECKS                                                 -->
<!-- ================================================================ -->

<!-- Each file must end with a newline -->
<module name="NewlineAtEndOfFile"/>

<!-- Max line length: 150 characters -->
<module name="LineLength">
    <property name="max" value="150"/>
    <message key="maxLineLength"
             value="Line is longer than 150 characters (found {0})."/>
</module>

<!-- No trailing whitespace -->
<module name="RegexpSingleline">
    <property name="format" value="\s+$"/>
    <property name="message" value="Line has trailing whitespace."/>
</module>

<module name="TreeWalker">

    <!-- ============================================================ -->
    <!-- NAMING CONVENTIONS                                            -->
    <!-- ============================================================ -->

    <!-- Classes and interfaces: PascalCase -->
    <module name="TypeName">
        <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        <message key="name.invalidPattern"
                 value="Class/interface name ''{0}'' must be PascalCase."/>
    </module>

    <!-- Methods: camelCase -->
    <module name="MethodName">
        <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        <message key="name.invalidPattern"
                 value="Method name ''{0}'' must be camelCase."/>
    </module>

    <!-- Local variables: camelCase -->
    <module name="LocalVariableName">
        <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        <message key="name.invalidPattern"
                 value="Local variable ''{0}'' must be camelCase."/>
    </module>

    <!-- Instance fields: camelCase -->
    <module name="MemberName">
        <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        <message key="name.invalidPattern"
                 value="Field name ''{0}'' must be camelCase."/>
    </module>

    <!-- Parameters: camelCase -->
    <module name="ParameterName">
        <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        <message key="name.invalidPattern"
                 value="Parameter name ''{0}'' must be camelCase."/>
    </module>

    <!-- Constants: UPPER_SNAKE_CASE -->
    <module name="ConstantName">
        <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        <message key="name.invalidPattern"
                 value="Constant ''{0}'' must be UPPER_SNAKE_CASE."/>
    </module>

    <!-- ============================================================ -->
    <!-- BRACES — Google style                                         -->
    <!-- Opening brace at end of line, closing brace on its own line  -->
    <!-- Exception: } catch, } else, } finally on same line as }      -->
    <!-- ============================================================ -->

    <!-- Braces required for all control structures -->
    <module name="NeedBraces">
        <property name="tokens" value="LITERAL_IF, LITERAL_ELSE, LITERAL_FOR, LITERAL_WHILE, LITERAL_DO"/>
        <message key="needBraces"
                 value="''{0}'' construct must use ''{'' and ''}''."/>
    </module>

    <!-- Opening brace at end of line -->
    <module name="LeftCurly">
        <property name="option" value="eol"/>
    </module>

    <!-- Closing brace:
         - } catch, } else, } finally: same line as closing brace
         - all other blocks: alone on its own line -->
    <module name="RightCurly">
        <property name="option" value="same"/>
        <property name="tokens" value="LITERAL_TRY, LITERAL_CATCH, LITERAL_FINALLY, LITERAL_ELSE"/>
    </module>
    <module name="RightCurly">
        <property name="option" value="alone"/>
        <property name="tokens" value="CLASS_DEF, METHOD_DEF, CTOR_DEF, LITERAL_FOR, LITERAL_WHILE, LITERAL_DO, STATIC_INIT, INSTANCE_INIT, ANNOTATION_DEF, ENUM_DEF, INTERFACE_DEF, RECORD_DEF, COMPACT_CTOR_DEF"/>
    </module>

    <!-- No empty blocks without a comment -->
    <module name="EmptyBlock">
        <property name="option" value="text"/>
    </module>

    <!-- ============================================================ -->
    <!-- IMPORTS                                                       -->
    <!-- ============================================================ -->

    <!-- No duplicate imports -->
    <module name="RedundantImport"/>

    <!-- No unused imports -->
    <module name="UnusedImports"/>

    <!-- Star imports ARE allowed — no AvoidStarImport rule -->

    <!-- ============================================================ -->
    <!-- CODE QUALITY                                                  -->
    <!-- ============================================================ -->

    <!-- No magic numbers — HTTP status codes and common values allowed -->
    <module name="MagicNumber">
        <property name="ignoreNumbers" value="-1, 0, 1, 2, 200, 201, 204, 400, 401, 403, 404, 409, 500"/>
        <property name="ignoreAnnotation" value="true"/>
        <property name="ignoreHashCodeMethod" value="true"/>
    </module>

    <!-- No empty statements (stray semicolons) -->
    <module name="EmptyStatement"/>

    <!-- equals() must be overridden with hashCode() -->
    <module name="EqualsHashCode"/>

    <!-- No assignments inside expressions -->
    <module name="InnerAssignment"/>

    <!-- Default clause in switch must come last -->
    <module name="DefaultComesLast"/>

    <!-- No fall-through in switch without comment -->
    <module name="FallThrough"/>

    <!-- String comparisons must use .equals() not == -->
    <module name="StringLiteralEquality"/>

    <!-- ============================================================ -->
    <!-- MODIFIERS                                                     -->
    <!-- ============================================================ -->

    <!-- Modifier order: public/protected/private static final -->
    <module name="ModifierOrder"/>

    <!-- No redundant modifiers (e.g. public in interfaces) -->
    <module name="RedundantModifier"/>

</module>

</module>
